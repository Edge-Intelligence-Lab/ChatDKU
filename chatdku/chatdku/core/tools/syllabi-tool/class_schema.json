{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Class",
  "type": "object",
  "properties": {
    "class_id": { "type": "integer" },
    "course_id": { "type": "string", "maxLength": 10 },
    "title": { "type": "string" },
    "credit_hours": { "type": "number" },
    "course_format": { "type": "string" },
    "prerequisites": { "type": "string" },
    "description": { "type": "string" },
    "learning_outcomes": { "type": "array", "items": { "type": "string" } },
    "required_textbook": { "type": "string" },
    "optional_textbooks": { "type": "array", "items": { "type": "string" } },
    "academic_policies": { "type": "string" },
    "instructor_email": { "type": "string" },
    "instructor_name": { "type": "string" },
    "office_location": { "type": "string" },
    "office_hours": { "type": "string" },
    "biography": { "type": "string" },
    "semester": { "type": "string", "maxLength": 20 },
    "session": { "type": "string", "maxLength": 10 },
    "schedule_days": { "type": "array", "items": { "type": "string" } },
    "schedule_time": { "type": "string" },
    "location": { "type": "string" },
    "recitation_time": { "type": "string" },
    "recitation_location": { "type": "string" },
    "grading_policy": { "type": "object" },
    "final_exam_weight": { "type": "integer" },
    "midterm_weight": { "type": "integer" },
    "homework_weight": { "type": "integer" },
    "presentation_weight": { "type": "integer" },
    "grading_scale": { "type": "string" },
    "assignment_policy": { "type": "string" },
    "communication_policy": { "type": "string" },
    "teaching_methods": { "type": "string" },
    "group_work": { "type": "boolean" },
    "canvas_enabled": { "type": "boolean" }
  },
  "required": [
    "course_id",
    "title",
    "credit_hours",
    "course_format",
    "academic_policies",
    "instructor_email"
  ],
  "additionalProperties": false
}
